# Shared settings
AI_PROVIDER=openai
AI_MODEL=gpt-4.1
OPENAI_API_KEY=sk-...
REPORT_FREQUENCY=daily
EMAIL_RECIPIENTS=your.email@example.com

# ------------------------
# AWS (CloudFormation)
# ------------------------
AWS_PROFILE=your-aws-profile
AWS_REGION=eu-north-1
AWS_STACK_NAME=cost-advisor-aws
AWS_COST_BUCKET=cost-advisor-raw-cost-data
AWS_ANALYSIS_BUCKET=cost-advisor-analysis-data
AWS_REPORT_SENDER_EMAIL=noreply@example.com

# ------------------------
# Azure (Bicep)
# ------------------------
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_LOCATION=westeurope
AZURE_RESOURCE_GROUP=rg-cost-advisor
AZURE_DEPLOYMENT_NAME=cost-advisor-azure
AZURE_STORAGE_ACCOUNT=stcostadvisor0001
AZURE_REPORT_SENDER_EMAIL=noreply@example.com

# ------------------------
# GCP (Terraform)
# ------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_TF_STATE_BUCKET=cost-advisor-tf-state
GCP_COST_DATASET=cost_advisor
GCP_ANALYSIS_BUCKET=cost-advisor-analysis-data
GCP_REPORT_SENDER_EMAIL=noreply@example.com
